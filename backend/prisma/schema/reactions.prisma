model Reaction {
  id            String            @id @default(cuid())
  name          String
  mechanismType String
  form          String
  tags          String?
  status        ReviewStatus      @default(PENDING)
  authorId      String
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  author        User              @relation(fields: [authorId], references: [id])
  patterns      ReactionPattern[]
  sections      ReactionSection[]
  reviews       Review[]

  @@map("reaction")
}

model Review {
  id         String       @id @default(cuid())
  reactionId String
  reviewerId String
  status     ReviewStatus
  comment    String?
  createdAt  DateTime     @default(now())
  reaction   Reaction     @relation(fields: [reactionId], references: [id], onDelete: Cascade)
  reviewer   User         @relation(fields: [reviewerId], references: [id])

  @@map("review")
}

model ReactionPattern {
  id         String         @id @default(cuid())
  name       String
  reactionId String
  molecules  MoleculeRole[]
  reaction   Reaction       @relation(fields: [reactionId], references: [id], onDelete: Cascade)

  @@map("reaction_pattern")
}

model MoleculeRole {
  id        String          @id @default(cuid())
  smarts    String
  name      String
  role      String
  patternId String
  pattern   ReactionPattern @relation(fields: [patternId], references: [id], onDelete: Cascade)

  @@map("molecule_role")
}

model ReactionSection {
  id              String               @id @default(cuid())
  sectionType     String
  reactionId      String
  acidityBasicity String               @default("-")
  concentration   String               @default("-")
  duration        String               @default("-")
  hydro           String               @default("-")
  microwave       String               @default("-")
  pressure        String               @default("-")
  solvent         String               @default("-")
  temperature     String               @default("-")
  reaction        Reaction             @relation(fields: [reactionId], references: [id], onDelete: Cascade)
  descriptions    SectionDescription[]
  reactions       SectionReaction[]

  @@map("reaction_section")
}

model SectionReaction {
  id        String          @id @default(cuid())
  value     String
  sectionId String
  section   ReactionSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)

  @@map("section_reaction")
}

model SectionDescription {
  id          String          @id @default(cuid())
  description String
  refPageNo   String?
  sectionId   String
  section     ReactionSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)

  @@map("section_description")
}

enum ReviewStatus {
  PENDING
  APPROVED
  REJECTED
}
