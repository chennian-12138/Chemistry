model Draft {
    id        String   @id @default(cuid())
    authorId  String
    name      String
    data      Json
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
    author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)

    @@index([authorId])
    @@map("draft")
}
